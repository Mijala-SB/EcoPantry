package com.ecopantry.app.data

import androidx.room.Dao
import androidx.room.Insert
import androidx.room.OnConflictStrategy
import androidx.room.Query
import kotlinx.coroutines.flow.Flow

@Dao
interface NotificationTableDao {

    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun insert(notification: NotificationTable)

    @Query("SELECT * FROM notification_table WHERE user_id = :userId ORDER BY timestamp DESC")
    fun getAllForUser(userId: String): Flow<List<NotificationTable>>

    @Query("SELECT COUNT(*) FROM notification_table WHERE user_id = :userId AND is_read = 0")
    fun getUnreadCount(userId: String): Flow<Int>

    @Query("UPDATE notification_table SET is_read = 1 WHERE notification_id = :id")
    suspend fun markAsRead(id: String)

    @Query("UPDATE notification_table SET is_read = 1 WHERE user_id = :userId")
    suspend fun markAllAsRead(userId: String)

    @Query("DELETE FROM notification_table WHERE notification_id = :id")
    suspend fun delete(id: String)

    @Query("DELETE FROM notification_table WHERE user_id = :userId")
    suspend fun clearAll(userId: String)

    /** Avoids duplicate expiry alerts being created every time the worker runs (FR11). */
    @Query(
        "SELECT COUNT(*) FROM notification_table WHERE related_item_id = :itemId " +
        "AND type = 'EXPIRY_ALERT' AND timestamp > :sinceMillis"
    )
    suspend fun countRecentExpiryAlertsFor(itemId: String, sinceMillis: Long): Int
}
